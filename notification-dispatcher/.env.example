# Copy to .env and adjust as needed. Docker Compose reads .env automatically.
# The app's application.yml already defaults to these local values, so exporting them is optional —
# do it (or `set -a; source .env; set +a`) only when pointing the app at non-local infrastructure.

# SA password used by both the SQL Server container and the app's datasource.
MSSQL_SA_PASSWORD=Str0ng!Passw0rd

# App datasource (override the local defaults in application.yml).
SPRING_DATASOURCE_URL=jdbc:sqlserver://localhost:1433;databaseName=dispatcher;encrypt=false;trustServerCertificate=true
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=Str0ng!Passw0rd

# Kafka broker.
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
